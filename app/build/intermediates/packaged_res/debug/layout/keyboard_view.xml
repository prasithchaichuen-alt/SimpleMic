<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="3"
    android:rowCount="5"
    android:padding="5dp"
    android:background="#000000">

    <ImageButton
        android:id="@+id/mic_button"
        android:layout_width="0dp"
        android:layout_height="90dp"
        android:layout_columnWeight="1"
        android:layout_columnSpan="3"
        android:layout_margin="3dp"
        android:background="@drawable/btn_style"
        android:backgroundTint="#2D2D2D"
        android:src="@android:drawable/ic_btn_speak_now"
        android:scaleType="fitCenter"
        android:tint="#FF5252" />

    <Button android:id="@+id/btn1" style="@style/NumBtn" android:text="1" />
    <Button android:id="@+id/btn2" style="@style/NumBtn" android:text="2" />
    <Button android:id="@+id/btn3" style="@style/NumBtn" android:text="3" />
    <Button android:id="@+id/btn4" style="@style/NumBtn" android:text="4" />
    <Button android:id="@+id/btn5" style="@style/NumBtn" android:text="5" />
    <Button android:id="@+id/btn6" style="@style/NumBtn" android:text="6" />
    <Button android:id="@+id/btn7" style="@style/NumBtn" android:text="7" />
    <Button android:id="@+id/btn8" style="@style/NumBtn" android:text="8" />
    <Button android:id="@+id/btn9" style="@style/NumBtn" android:text="9" />
    <Button android:id="@+id/btn_dot" style="@style/NumBtn" android:text="." />
    <Button android:id="@+id/btn0" style="@style/NumBtn" android:text="0" />
    <Button android:id="@+id/btn_del" style="@style/NumBtn" android:text="⌫" android:backgroundTint="#3D1A1A" android:textColor="#FF5252" />
</GridLayout>
